{
  "name": "openowl",
  "version": "0.1.0",
  "description": "Project intelligence, token tracking, and learning memory middleware for OpenCode",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "openowl": "dist/cli/bin.js"
  },
  "files": [
    "dist/",
    "src/templates/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run build:dashboard",
    "build:cli": "tsc",
    "build:dashboard": "cd src/dashboard/app && npx vite build",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^12.0.0",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "puppeteer-core": "^24.40.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/openowl"
  },
  "keywords": [
    "opencode",
    "ai",
    "middleware",
    "token-tracking",
    "learning-memory",
    "project-intelligence"
  ]
}
